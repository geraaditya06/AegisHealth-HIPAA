DATABASE_URL=sqlite:///./aegishealth.db
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=

# ── CORS (comma-separated list of allowed frontend origins) ──────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Background scan queue ────────────────────────────────────────────────────
# Number of concurrent background scan workers.
SCAN_WORKERS=3
# Number of automatic retries after the first attempt fails.
SCAN_MAX_RETRIES=1
# Soft guard for a single scan's duration (seconds).
SCAN_TIMEOUT_SECONDS=600

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
